server {
    listen 80;
    server_name share.bxota.com;

    # Redirect HTTP → HTTPS
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name share.bxota.com;

    ssl_certificate     /etc/letsencrypt/live/share.bxota.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/share.bxota.com/privkey.pem;

    # API only — file transfers go directly client ↔ R2
    location / {
        proxy_pass         http://127.0.0.1:8000;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;

        # Allow large metadata payloads (not file bodies)
        client_max_body_size 1m;
    }
}
